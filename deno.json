{
  "name": "tribbledb",
  "version": "1.0.0",
  "exports": {
    ".": "./src/mod.ts",
    "./v2": "./src/v2/mod.ts"
  },
  "tasks": {
    "test": "deno test --allow-read --allow-write",
    "check": "deno check *.ts indices/*.ts",
    "fmt": "deno fmt --ignore=dist/",
    "lint": "deno lint --ignore=dist/",
    "coverage": "deno test --coverage=coverage --allow-read --allow-write && deno coverage coverage --lcov --output=coverage.lcov"
  },
  "exclude": [
    "dist/",
    "coverage/"
  ],
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "fmt": {
    "exclude": [
      "dist/"
    ]
  },
  "lint": {
    "exclude": [
      "dist/"
    ]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "peach": "https://deno.land/x/peach_ts@0.4.2/src/mod.ts",
    "std/file-server": "https://deno.land/std@0.224.0/http/file_server.ts",
    "docopt": "https://deno.land/x/docopt@v1.0.7/mod.ts"
  }
}
